---
import Layout from '../layouts/Layout.astro';
import MetricCard from '../components/MetricCard.astro';
---

<Layout 
  title="Online BMI & Calorie Calculator - Health Parameter Tracker" 
  description="Calculate your BMR, TDEE, and BMI online. Find target maintenance calories, weight loss calorie plans, and custom diet profiles (Keto, Mediterranean, Sugar-Free)."
  activeTab="health"
>
  <div class="mb-12">
    <div class="font-mono text-xs uppercase tracking-wider text-mute mb-2">01. Body Composition</div>
    <h1 class="font-sans text-3xl md:text-5xl font-semibold tracking-tight text-ink leading-none">
      Health & Calorie Planner
    </h1>
    <p class="text-body text-sm mt-3 max-w-[600px]">
      Calculate BMR, TDEE, target caloric intake, and precise macronutrient splits customized for your fitness objective.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <!-- Left Column: Inputs Form -->
    <div class="lg:col-span-5 bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-6">
      <h2 class="font-sans text-lg font-semibold tracking-tight border-b border-hairline pb-3">Parameters</h2>
      
      <!-- Gender Selection -->
      <div>
        <label class="block font-mono text-xs uppercase tracking-wider text-body mb-2">Gender</label>
        <div class="grid grid-cols-2 gap-3">
          <label class="flex items-center justify-center h-10 border border-hairline rounded-sm cursor-pointer select-none text-sm hover:bg-canvas-soft-2 transition-all has-[:checked]:bg-primary has-[:checked]:text-on-primary has-[:checked]:border-primary">
            <input type="radio" name="gender" value="male" checked class="sr-only" />
            Male
          </label>
          <label class="flex items-center justify-center h-10 border border-hairline rounded-sm cursor-pointer select-none text-sm hover:bg-canvas-soft-2 transition-all has-[:checked]:bg-primary has-[:checked]:text-on-primary has-[:checked]:border-primary">
            <input type="radio" name="gender" value="female" class="sr-only" />
            Female
          </label>
        </div>
      </div>

      <!-- Age Input -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label for="age" class="font-mono text-xs uppercase tracking-wider text-body">Age</label>
          <input type="number" id="age-num" min="15" max="80" value="28" class="w-16 h-7 border border-hairline bg-canvas text-ink rounded-sm px-2 text-xs font-mono text-right focus:border-hairline-strong outline-none" />
        </div>
        <input type="range" id="age" min="15" max="80" value="28" class="w-full mt-1" />
      </div>

      <!-- Height Input Section -->
      <div>
        <div class="flex justify-between items-center mb-2">
          <label class="font-mono text-xs uppercase tracking-wider text-body">Height</label>
          <select id="height-unit" class="bg-canvas border border-hairline text-xs font-mono rounded-sm px-2 py-0.5 outline-none hover:border-hairline-strong transition-colors">
            <option value="metric">Metric (cm)</option>
            <option value="imperial">Imperial (ft/in)</option>
          </select>
        </div>
        
        <!-- Height in cm (Metric) -->
        <div id="height-metric-container" class="mt-1">
          <div class="flex gap-2 items-center">
            <input type="number" id="height-cm" value="175" min="100" max="250" class="w-full h-10 border border-hairline rounded-sm px-3 text-sm focus:border-hairline-strong outline-none" />
            <span class="font-mono text-xs text-mute w-8">cm</span>
          </div>
        </div>

        <!-- Height in ft/in (Imperial) -->
        <div id="height-imperial-container" class="mt-1 hidden grid grid-cols-2 gap-2">
          <div class="flex gap-2 items-center">
            <input type="number" id="height-ft" value="5" min="3" max="8" class="w-full h-10 border border-hairline rounded-sm px-3 text-sm focus:border-hairline-strong outline-none" />
            <span class="font-mono text-xs text-mute">ft</span>
          </div>
          <div class="flex gap-2 items-center">
            <input type="number" id="height-in" value="9" min="0" max="11" class="w-full h-10 border border-hairline rounded-sm px-3 text-sm focus:border-hairline-strong outline-none" />
            <span class="font-mono text-xs text-mute">in</span>
          </div>
        </div>
      </div>

      <!-- Weight Input Section -->
      <div>
        <div class="flex justify-between items-center mb-2">
          <label class="font-mono text-xs uppercase tracking-wider text-body">Weight</label>
          <select id="weight-unit" class="bg-canvas border border-hairline text-xs font-mono rounded-sm px-2 py-0.5 outline-none hover:border-hairline-strong transition-colors">
            <option value="metric">Metric (kg)</option>
            <option value="imperial">Imperial (lbs)</option>
          </select>
        </div>
        <div class="flex gap-2 items-center">
          <input type="number" id="weight" value="70" min="30" max="200" class="w-full h-10 border border-hairline rounded-sm px-3 text-sm focus:border-hairline-strong outline-none" />
          <span id="weight-unit-label" class="font-mono text-xs text-mute w-8">kg</span>
        </div>
      </div>

      <!-- Activity Level Select -->
      <div>
        <label for="activity" class="block font-mono text-xs uppercase tracking-wider text-body mb-2">Activity Level</label>
        <select id="activity" class="w-full h-10 bg-canvas border border-hairline rounded-sm px-3 text-sm outline-none focus:border-hairline-strong transition-colors">
          <option value="1.2">Sedentary (little to no exercise)</option>
          <option value="1.375">Lightly Active (exercise 1-3 days/week)</option>
          <option value="1.55">Moderately Active (exercise 3-5 days/week)</option>
          <option value="1.725">Very Active (hard exercise 6-7 days/week)</option>
          <option value="1.9">Extra Active (highly active job/double training)</option>
        </select>
      </div>

      <!-- Fitness Goal Select -->
      <div>
        <label for="goal" class="block font-mono text-xs uppercase tracking-wider text-body mb-2">Fitness Goal</label>
        <select id="goal" class="w-full h-10 bg-canvas border border-hairline rounded-sm px-3 text-sm outline-none focus:border-hairline-strong transition-colors">
          <option value="maintain">Maintain Healthy Lifestyle</option>
          <option value="loss">Weight Loss</option>
          <option value="fat-loss">Fat Loss (High Protein Deficit)</option>
          <option value="gain">Weight Gain</option>
          <option value="bodybuilding">Body Building</option>
          <option value="lean-mass">Lean Mass Building</option>
        </select>
      </div>

      <!-- Country Selection -->
      <div>
        <label for="country" class="block font-mono text-xs uppercase tracking-wider text-body mb-2">Country</label>
        <select id="country" class="w-full h-10 bg-canvas border border-hairline rounded-sm px-3 text-sm outline-none focus:border-hairline-strong transition-colors" required>
          <option value="" disabled selected>Select Country</option>
          <option value="IN">India</option>
          <option value="US">United States</option>
          <option value="UK">United Kingdom</option>
          <option value="AU">Australia</option>
          <option value="JP">Japan</option>
          <option value="BR">Brazil</option>
          <option value="DE">Germany</option>
          <option value="ZA">South Africa</option>
          <option value="AE">United Arab Emirates</option>
        </select>
      </div>

      <!-- City Selection -->
      <div>
        <label for="city" class="block font-mono text-xs uppercase tracking-wider text-body mb-2">City</label>
        <select id="city" class="w-full h-10 bg-canvas border border-hairline rounded-sm px-3 text-sm outline-none focus:border-hairline-strong transition-colors" required disabled>
          <option value="" disabled selected>Select a country first</option>
        </select>
      </div>

      <!-- Dietary Preference -->
      <div>
        <label for="dietary-preference" class="block font-mono text-xs uppercase tracking-wider text-body mb-2">Dietary Preference</label>
        <select id="dietary-preference" class="w-full h-10 bg-canvas border border-hairline rounded-sm px-3 text-sm outline-none focus:border-hairline-strong transition-colors">
          <option value="veg">Vegetarian</option>
          <option value="non-veg" selected>Non-Vegetarian</option>
        </select>
      </div>

      <!-- Calculate Button -->
      <button 
        id="calculate-btn"
        class="w-full h-11 bg-primary text-on-primary font-mono text-xs font-semibold uppercase tracking-wider rounded-md hover:opacity-90 transition-all shadow-vercel-md cursor-pointer flex items-center justify-center gap-2 mt-6"
      >
        ⚡ Calculate & Generate Plan
      </button>
    </div>


    <!-- Right Column: Outputs -->
    <div class="lg:col-span-7 space-y-6">
      
      <!-- Core Metrics Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <MetricCard label="BMR" id="bmr-card" value="--" subtitle="Basal Metabolic Rate" />
        <MetricCard label="TDEE" id="tdee-card" value="--" subtitle="Total Energy Expenditure" />
        <MetricCard label="Target Calories" id="target-card" value="--" subtitle="Daily Caloric Intake" highlighted={true} />
        <MetricCard label="BMI & Target Weight" id="bmi-card" value="--" subtitle="Healthy Target: --" />
      </div>

      <!-- Macronutrients Card -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-md">
        <h3 class="font-sans text-lg font-semibold tracking-tight border-b border-hairline pb-3 mb-6">Macronutrient Target Split</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
          
          <!-- Interactive SVG Donut Chart (MD: cols 5) -->
          <div class="md:col-span-5 flex justify-center">
            <div class="relative w-44 h-44">
              <!-- SVG Donut Circles -->
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                <!-- Background ring -->
                <circle cx="60" cy="60" r="50" stroke="var(--color-canvas-soft-2)" stroke-width="12" fill="transparent" />
                
                <!-- Segments (circumference is 2 * pi * 50 = 314.16) -->
                <!-- Carbs segment -->
                <circle id="donut-carbs" cx="60" cy="60" r="50" stroke="#0070f3" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" stroke-linecap="round" />
                <!-- Protein segment -->
                <circle id="donut-protein" cx="60" cy="60" r="50" stroke="#ff0080" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" stroke-linecap="round" />
                <!-- Fat segment -->
                <circle id="donut-fat" cx="60" cy="60" r="50" stroke="#f9cb28" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" stroke-linecap="round" />
              </svg>
              
              <!-- Center content label -->
              <div class="absolute inset-0 flex flex-col justify-center items-center">
                <span class="text-xs text-mute font-mono uppercase tracking-wider">Macros</span>
                <span id="center-cal" class="text-lg font-semibold tracking-tight mt-1">-- kcal</span>
              </div>
            </div>
          </div>

          <!-- Legend & Detailed Grams (MD: cols 7) -->
          <div class="md:col-span-7 space-y-4">
            <!-- Carb Legend -->
            <div class="flex items-center justify-between border-b border-hairline pb-2">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-[#0070f3]"></span>
                <span class="text-sm font-medium">Carbohydrate</span>
                <span id="carb-pct" class="font-mono text-xs text-mute">(50%)</span>
              </div>
              <div class="text-right">
                <div id="carb-g" class="font-sans font-semibold text-sm">-- g</div>
                <div id="carb-cal" class="font-mono text-[10px] text-mute">-- kcal</div>
              </div>
            </div>

            <!-- Protein Legend -->
            <div class="flex items-center justify-between border-b border-hairline pb-2">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-[#ff0080]"></span>
                <span class="text-sm font-medium">Protein</span>
                <span id="protein-pct" class="font-mono text-xs text-mute">(20%)</span>
              </div>
              <div class="text-right">
                <div id="protein-g" class="font-sans font-semibold text-sm">-- g</div>
                <div id="protein-cal" class="font-mono text-[10px] text-mute">-- kcal</div>
              </div>
            </div>

            <!-- Fat Legend -->
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-[#f9cb28]"></span>
                <span class="text-sm font-medium">Fat</span>
                <span id="fat-pct" class="font-mono text-xs text-mute">(30%)</span>
              </div>
              <div class="text-right">
                <div id="fat-g" class="font-sans font-semibold text-sm">-- g</div>
                <div id="fat-cal" class="font-mono text-[10px] text-mute">-- kcal</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Educational note card -->
      <div class="p-4 border border-hairline rounded-md bg-canvas-soft-2 font-mono text-xs text-body leading-relaxed flex gap-3">
        <span class="text-link">ℹ</span>
        <span>
          Macronutrient splits are defined by targets: Weight/Fat loss emphasizes higher Protein ratios to preserve skeletal muscle mass during deficits. Body building and Gain prioritize higher Carbohydrates to fuel training intensity and sustain glycogen levels.
        </span>
      </div>
    </div>
  </div>

  <!-- Diet Plan Section -->
  <div id="diet-plan-section" class="mt-12 w-full space-y-8 print:mt-0 print:space-y-4">
    <div class="border-b border-hairline pb-4 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
      <div>
        <div class="font-mono text-xs uppercase tracking-wider text-mute mb-2">02. Daily Nutrition Plan</div>
        <h2 class="font-sans text-2xl md:text-3xl font-semibold tracking-tight text-ink">Personalized Diet Chart</h2>
      </div>
      <div class="flex items-center gap-3">
        <button 
          id="reset-diet-btn"
          class="hidden md:flex items-center gap-2 px-4 py-2 border border-hairline rounded-md bg-canvas hover:bg-canvas-soft-2 font-mono text-xs font-medium cursor-pointer transition-all shadow-vercel-sm print:hidden text-mute hover:text-error"
        >
          🔄 Reset Plan
        </button>
        <button 
          id="print-diet-btn"
          class="hidden md:flex items-center gap-2 px-4 py-2 border border-hairline rounded-md bg-canvas hover:bg-canvas-soft-2 font-mono text-xs font-medium cursor-pointer transition-all shadow-vercel-sm print:hidden"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4"></path>
          </svg>
          Export Diet PDF / Print
        </button>
      </div>
    </div>



    <!-- Empty State -->
    <div id="diet-empty-state" class="bg-canvas-soft border border-hairline rounded-lg p-12 text-center shadow-vercel-sm">
      <div class="w-12 h-12 rounded-full border border-hairline flex items-center justify-center mx-auto mb-4 bg-canvas text-mute text-lg">
        📍
      </div>
      <h3 class="font-sans text-base font-semibold text-ink mb-2">Location Required</h3>
      <p class="text-body text-sm max-w-[450px] mx-auto mb-6">
        Please select your Country and City in the Parameters panel above to generate your customized, culturally aligned full-day diet plan.
      </p>
      <button 
        id="focus-location-btn"
        class="px-4 py-2 rounded-full bg-primary text-on-primary font-mono text-xs font-semibold hover:opacity-90 shadow-vercel-md transition-all cursor-pointer"
      >
        Select Location
      </button>
    </div>

    <!-- Active Diet Plan Panel (hidden by default) -->
    <div id="diet-active-panel" class="hidden space-y-8">
      <!-- Habits & Timezone Card -->
      <div class="p-5 border border-hairline rounded-lg bg-canvas-soft-2 text-sm leading-relaxed flex flex-col md:flex-row gap-4 justify-between items-start md:items-center">
        <div class="space-y-1">
          <div class="font-mono text-xs uppercase tracking-wider text-link font-semibold">Eating Habits & Local Timing</div>
          <p id="diet-habits-text" class="text-body max-w-[800px]"></p>
        </div>
        <div class="bg-canvas border border-hairline rounded-sm px-3 py-1.5 font-mono text-xs text-mute flex items-center gap-1.5 whitespace-nowrap">
          <span class="w-2 h-2 rounded-full bg-success"></span>
          Timezone: <span id="diet-timezone-text" class="text-ink"></span>
        </div>
      </div>

      <!-- Timeline of Meals (Grid) -->
      <div id="meals-timeline-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Dynamic Meal Cards will be injected here -->
      </div>

      <div class="flex justify-center mt-2 print:hidden">
        <button id="add-custom-meal-btn" class="flex items-center gap-2 px-4 py-2 border border-dashed border-hairline hover:border-hairline-strong rounded-md bg-canvas hover:bg-canvas-soft-2 font-mono text-xs font-medium cursor-pointer transition-all shadow-vercel-sm">
          + Add Custom Meal Card
        </button>
      </div>

      <!-- Target vs Actual Summary Block -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-md grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Left: Macro Comparison Table -->
        <div class="lg:col-span-7 space-y-4">
          <h3 class="font-sans text-base font-semibold tracking-tight border-b border-hairline pb-2">Target vs. Planned Intake</h3>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left font-sans text-sm">
              <thead>
                <tr class="border-b border-hairline font-mono text-[10px] text-mute uppercase tracking-wider">
                  <th class="py-2">Nutrient</th>
                  <th class="py-2 text-right">Daily Target</th>
                  <th class="py-2 text-right">Planned Menu</th>
                  <th class="py-2 text-right">Difference</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-hairline">
                <tr>
                  <td class="py-2 font-medium">Calories</td>
                  <td id="summary-target-cal" class="py-2 text-right font-mono text-xs">-- kcal</td>
                  <td id="summary-actual-cal" class="py-2 text-right font-mono text-xs">-- kcal</td>
                  <td id="summary-diff-cal" class="py-2 text-right font-mono text-xs font-semibold">--</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-[#ff0080]"></span> Protein
                  </td>
                  <td id="summary-target-prot" class="py-2 text-right font-mono text-xs">-- g</td>
                  <td id="summary-actual-prot" class="py-2 text-right font-mono text-xs">-- g</td>
                  <td id="summary-diff-prot" class="py-2 text-right font-mono text-xs font-semibold">--</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-[#0070f3]"></span> Carbohydrate
                  </td>
                  <td id="summary-target-carb" class="py-2 text-right font-mono text-xs">-- g</td>
                  <td id="summary-actual-carb" class="py-2 text-right font-mono text-xs">-- g</td>
                  <td id="summary-diff-carb" class="py-2 text-right font-mono text-xs font-semibold">--</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-[#f9cb28]"></span> Fat
                  </td>
                  <td id="summary-target-fat" class="py-2 text-right font-mono text-xs">-- g</td>
                  <td id="summary-actual-fat" class="py-2 text-right font-mono text-xs">-- g</td>
                  <td id="summary-diff-fat" class="py-2 text-right font-mono text-xs font-semibold">--</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="flex items-center gap-2 mt-4">
            <span id="nutritional-match-badge" class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium font-mono">
              <!-- Dynamically populated badge -->
            </span>
          </div>
        </div>

        <!-- Right: Micronutrients Aggregation -->
        <div class="lg:col-span-5 space-y-4">
          <h3 class="font-sans text-base font-semibold tracking-tight border-b border-hairline pb-2">Total Micronutrient Estimate</h3>
          
          <div id="summary-micros-list" class="grid grid-cols-2 gap-x-4 gap-y-2 font-mono text-xs text-body">
            <!-- Dynamically populated micros -->
          </div>
          <p class="text-mute text-[10px] leading-relaxed pt-2">
            * Micronutrient estimates are calculated based on standard agricultural database averages for raw ingredients and will vary slightly depending on preparation methods.
          </p>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  @media print {
    body {
      background: white !important;
      color: black !important;
    }
    header, footer, #theme-toggle, .lg\:col-span-5, #print-diet-btn, #focus-location-btn, .p-4.border.border-hairline {
      display: none !important;
    }
    .lg\:col-span-7 {
      width: 100% !important;
      max-width: 100% !important;
      flex: none !important;
    }
    #diet-plan-section {
      margin-top: 0 !important;
      padding: 0 !important;
      border: none !important;
      box-shadow: none !important;
    }
    #meals-timeline-container {
      grid-template-columns: 1fr !important;
      display: block !important;
    }
    .border {
      border-color: #ddd !important;
    }
    .shadow-vercel-sm, .shadow-vercel-md, .shadow-vercel-lg {
      box-shadow: none !important;
    }
  }
</style>


<script>
  function setupHealthCalculator() {
    // Inputs elements
    const genderInputs = document.getElementsByName('gender') as NodeListOf<HTMLInputElement>;
    const ageInput = document.getElementById('age') as HTMLInputElement;
    const ageNumInput = document.getElementById('age-num') as HTMLInputElement;
    const heightUnit = document.getElementById('height-unit') as HTMLSelectElement;
    const heightMetricContainer = document.getElementById('height-metric-container') as HTMLDivElement;
    const heightImperialContainer = document.getElementById('height-imperial-container') as HTMLDivElement;
    const heightCmInput = document.getElementById('height-cm') as HTMLInputElement;
    const heightFtInput = document.getElementById('height-ft') as HTMLInputElement;
    const heightInInput = document.getElementById('height-in') as HTMLInputElement;
    const weightUnit = document.getElementById('weight-unit') as HTMLSelectElement;
    const weightUnitLabel = document.getElementById('weight-unit-label') as HTMLSpanElement;
    const weightInput = document.getElementById('weight') as HTMLInputElement;
    const activitySelect = document.getElementById('activity') as HTMLSelectElement;
    const goalSelect = document.getElementById('goal') as HTMLSelectElement;

    // Display elements
    const bmrValue = document.querySelector('#bmr-card .font-sans') as HTMLDivElement;
    const tdeeValue = document.querySelector('#tdee-card .font-sans') as HTMLDivElement;
    const targetValue = document.querySelector('#target-card .font-sans') as HTMLDivElement;
    const bmiValue = document.querySelector('#bmi-card .font-sans') as HTMLDivElement;
    const bmiSubtitle = document.querySelector('#bmi-card .metric-subtitle') as HTMLDivElement;
    const centerCal = document.getElementById('center-cal') as HTMLSpanElement;

    const carbPctLabel = document.getElementById('carb-pct') as HTMLSpanElement;
    const carbGLbl = document.getElementById('carb-g') as HTMLDivElement;
    const carbCalLbl = document.getElementById('carb-cal') as HTMLDivElement;

    const proteinPctLabel = document.getElementById('protein-pct') as HTMLSpanElement;
