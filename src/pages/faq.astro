  <!-- Client-side script for accordion handling -->
  <script is:inline>
    function setupFaqAccordion() {
      const toggles = document.querySelectorAll('[data-faq-toggle]');
      toggles.forEach(toggle => {
        // Clear any existing listeners (safeguard for multiple executions on view swaps)
        const newToggle = toggle.cloneNode(true);
        toggle.parentNode.replaceChild(newToggle, toggle);
        
        newToggle.addEventListener('click', () => {
          const content = newToggle.nextElementSibling;
          const isOpen = newToggle.hasAttribute('data-open');

          // Close all other content sections
          document.querySelectorAll('[data-faq-toggle]').forEach(otherToggle => {
            if (otherToggle !== newToggle) {
              otherToggle.removeAttribute('data-open');
              const otherContent = otherToggle.nextElementSibling;
              if (otherContent) otherContent.style.maxHeight = null;
            }
          });

          // Toggle current
          if (isOpen) {
            newToggle.removeAttribute('data-open');
            content.style.maxHeight = null;
          } else {
            newToggle.setAttribute('data-open', '');
            content.style.maxHeight = content.scrollHeight + 'px';
          }
        });
      });
    }

    setupFaqAccordion();
    document.addEventListener('astro:page-load', setupFaqAccordion);
  </script>

