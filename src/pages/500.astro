---
import Layout from '../layouts/Layout.astro';
---

<Layout title="500: Server Error" description="An unexpected error occurred on WHealthCalculator.com.">
  <div class="flex-1 flex flex-col items-center justify-center text-center py-20">
    <div class="font-mono text-xs uppercase tracking-wider text-error mb-4">500 / INTERNAL_SERVER_ERROR</div>
    <h1 class="font-sans text-4xl md:text-6xl font-semibold tracking-tight text-ink mb-6 leading-none select-none">
      Something went wrong.
    </h1>
    <p class="text-body text-sm max-w-[480px] mb-8 font-sans">
      An unexpected internal server error occurred. Please try reloading the page, or contact support if the issue persists.
    </p>
    <div class="flex gap-3 justify-center">
      <a 
        href="/" 
        class="px-5 py-2.5 rounded-full bg-primary text-on-primary font-medium text-xs hover:opacity-90 shadow-vercel-md transition-all"
      >
        Go back home
      </a>
      <a 
        href="/contact" 
        class="px-5 py-2.5 rounded-full bg-canvas text-ink border border-hairline font-medium text-xs hover:bg-canvas-soft-2 shadow-vercel-sm transition-all"
      >
        Contact support
      </a>
    </div>
  </div>
</Layout>
