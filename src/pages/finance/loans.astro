---
import Layout from '../../layouts/Layout.astro';
import MetricCard from '../../components/MetricCard.astro';
---

<Layout 
  title="Home & Personal Loan EMI Calculator - Amortization Schedule Planner" 
  description="Calculate your monthly home or personal loan EMI using our online calculator. View complete principal and interest payment schedules and amortization tables."
  activeTab="loans"
>
  <div class="mb-12">
    <div class="font-mono text-xs uppercase tracking-wider text-mute mb-2">02. Debt & Liabilities</div>
    <h1 class="font-sans text-3xl md:text-5xl font-semibold tracking-tight text-ink leading-none">
      Loan EMI & Amortization Planner
    </h1>
    <p class="text-body text-sm mt-3 max-w-[600px]">
      Compute your monthly installments (EMI), interest payout profiles, and explore the complete amortization schedule for home and personal loans.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    <!-- Left Column: Inputs Form -->
    <div class="lg:col-span-5 bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-6">
      <h2 class="font-sans text-lg font-semibold tracking-tight border-b border-hairline pb-3">Loan Details</h2>

      <!-- Loan Type Select -->
      <div>
        <label for="loan-type" class="block font-mono text-xs uppercase tracking-wider text-body mb-2">Loan Type</label>
        <select id="loan-type" class="w-full h-10 bg-canvas border border-hairline rounded-sm px-3 text-sm outline-none focus:border-hairline-strong transition-colors">
          <option value="home">Home Loan (Housing Mortgage)</option>
          <option value="personal">Personal Loan / Auto Loan</option>
        </select>
      </div>

      <!-- Loan Amount Input -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label for="loan-amount" class="font-mono text-xs uppercase tracking-wider text-body">Loan Amount</label>
          <input type="number" id="loan-amount-num" min="100000" max="15000000" step="50000" value="5000000" class="w-28 h-7 border border-hairline bg-canvas text-ink rounded-sm px-2 text-xs font-mono text-right focus:border-hairline-strong outline-none" />
        </div>
        <input type="range" id="loan-amount" min="100000" max="15000000" step="50000" value="5000000" class="w-full mt-1" />
        <div class="flex justify-between text-[10px] text-mute font-mono mt-1">
          <span>₹1 Lakh</span>
          <span>₹1.5 Crore</span>
        </div>
      </div>

      <!-- Interest Rate Slider -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label for="loan-rate" class="font-mono text-xs uppercase tracking-wider text-body">Interest Rate (p.a. %)</label>
          <input type="number" id="loan-rate-num" min="5" max="20" step="0.1" value="8.5" class="w-16 h-7 border border-hairline bg-canvas text-ink rounded-sm px-2 text-xs font-mono text-right focus:border-hairline-strong outline-none" />
        </div>
        <input type="range" id="loan-rate" min="5" max="20" step="0.1" value="8.5" class="w-full mt-1" />
        <div class="flex justify-between text-[10px] text-mute font-mono mt-1">
          <span>5%</span>
          <span>20%</span>
        </div>
      </div>

      <!-- Tenure Slider -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label for="loan-tenure" class="font-mono text-xs uppercase tracking-wider text-body">Tenure (Years)</label>
          <input type="number" id="loan-tenure-num" min="1" max="30" value="20" class="w-16 h-7 border border-hairline bg-canvas text-ink rounded-sm px-2 text-xs font-mono text-right focus:border-hairline-strong outline-none" />
        </div>
        <input type="range" id="loan-tenure" min="1" max="30" value="20" class="w-full mt-1" />
        <div class="flex justify-between text-[10px] text-mute font-mono mt-1">
          <span>1 yr</span>
          <span>30 yrs</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Outputs -->
    <div class="lg:col-span-7 space-y-6">
      
      <!-- Metrics -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <MetricCard label="Monthly EMI" id="emi-card" value="--" subtitle="Installment Per Month" highlighted={true} />
        <MetricCard label="Principal Amount" id="principal-card" value="--" subtitle="Loan Amount Borrowed" />
        <MetricCard label="Total Interest" id="interest-card" value="--" subtitle="Payable Extra" />
        <MetricCard label="Total Amount" id="total-card" value="--" subtitle="Principal + Interest" />
      </div>

      <!-- Split Chart Card -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-md">
        <h3 class="font-sans text-base font-semibold tracking-tight border-b border-hairline pb-3 mb-6 font-medium">Payment Breakdown</h3>
        
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-center">
          <!-- Donut SVG -->
          <div class="md:col-span-5 flex justify-center">
            <div class="relative w-40 h-40">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
                <circle cx="60" cy="60" r="50" stroke="var(--color-canvas-soft-2)" stroke-width="12" fill="transparent" />
                
                <!-- Segments (Circumference ~314.16) -->
                <!-- Principal segment (Blue) -->
                <circle id="donut-principal" cx="60" cy="60" r="50" stroke="var(--color-link)" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" />
                <!-- Interest segment (Yellow) -->
                <circle id="donut-interest" cx="60" cy="60" r="50" stroke="#f9cb28" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" />
              </svg>
              
              <div class="absolute inset-0 flex flex-col justify-center items-center">
                <span class="text-[10px] text-mute font-mono uppercase">Total Paid</span>
                <span id="center-total" class="text-xs font-semibold mt-1">₹--</span>
              </div>
            </div>
          </div>

          <!-- Legend details -->
          <div class="md:col-span-7 space-y-4">
            <div class="flex items-center justify-between border-b border-hairline pb-2">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-[var(--color-link)]"></span>
                <span class="text-sm font-medium">Principal Loan Amount</span>
                <span id="legend-principal-pct" class="font-mono text-xs text-mute">(0%)</span>
              </div>
              <div id="legend-principal-val" class="font-sans font-semibold text-sm">₹0</div>
            </div>
            
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-[#f9cb28]"></span>
                <span class="text-sm font-medium">Total Interest Payable</span>
                <span id="legend-interest-pct" class="font-mono text-xs text-mute">(0%)</span>
              </div>
              <div id="legend-interest-val" class="font-sans font-semibold text-sm">₹0</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Collapsible Amortization Schedule -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm">
        <div class="flex justify-between items-center border-b border-hairline pb-3 mb-4">
          <h3 class="font-sans text-base font-semibold tracking-tight">Amortization Schedule</h3>
          <select id="schedule-view" class="bg-canvas border border-hairline text-xs font-mono rounded-sm px-2 py-1 outline-none hover:border-hairline-strong transition-colors">
            <option value="yearly">Yearly Breakdown</option>
            <option value="monthly">First 12 Months</option>
          </select>
        </div>

        <div class="overflow-x-auto max-h-80 scrollbar-thin">
          <table class="w-full text-left font-sans text-xs border-collapse">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2 font-mono uppercase text-mute">
                <th class="p-2 py-2">Timeline</th>
                <th class="p-2 py-2 text-right">Principal Paid</th>
                <th class="p-2 py-2 text-right">Interest Paid</th>
                <th class="p-2 py-2 text-right">Outstanding Balance</th>
              </tr>
            </thead>
            <tbody id="schedule-body">
              <!-- Rendered via JS -->
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function setupLoanCalculator() {
    const loanTypeSelect = document.getElementById('loan-type') as HTMLSelectElement;
    
    const amountInput = document.getElementById('loan-amount') as HTMLInputElement;
    const amountNum = document.getElementById('loan-amount-num') as HTMLInputElement;
 
    const rateInput = document.getElementById('loan-rate') as HTMLInputElement;
    const rateNum = document.getElementById('loan-rate-num') as HTMLInputElement;
 
    const tenureInput = document.getElementById('loan-tenure') as HTMLInputElement;
    const tenureNum = document.getElementById('loan-tenure-num') as HTMLInputElement;

    const emiCard = document.querySelector('#emi-card .font-sans') as HTMLDivElement;
    const principalCard = document.querySelector('#principal-card .font-sans') as HTMLDivElement;
    const interestCard = document.querySelector('#interest-card .font-sans') as HTMLDivElement;
    const totalCard = document.querySelector('#total-card .font-sans') as HTMLDivElement;

    const donutPrincipal = document.getElementById('donut-principal') as unknown as SVGCircleElement;
    const donutInterest = document.getElementById('donut-interest') as unknown as SVGCircleElement;
    const centerTotalVal = document.getElementById('center-total') as HTMLSpanElement;

    const legendPrincipalPct = document.getElementById('legend-principal-pct') as HTMLSpanElement;
    const legendPrincipalVal = document.getElementById('legend-principal-val') as HTMLDivElement;
    
    const legendInterestPct = document.getElementById('legend-interest-pct') as HTMLSpanElement;
    const legendInterestVal = document.getElementById('legend-interest-val') as HTMLDivElement;

    const scheduleView = document.getElementById('schedule-view') as HTMLSelectElement;
    const scheduleBody = document.getElementById('schedule-body') as HTMLTableSectionElement;

    const CIRCUMFERENCE = 314.16;

    // Listeners
    [loanTypeSelect, amountInput, rateInput, tenureInput, scheduleView, amountNum, rateNum, tenureNum].forEach(element => {
      element.addEventListener('input', calculate);
    });
 
    amountInput.addEventListener('input', () => {
      amountNum.value = amountInput.value;
    });
    amountNum.addEventListener('input', () => {
      let val = parseFloat(amountNum.value) || 0;
      amountInput.value = Math.max(100000, Math.min(15000000, val)).toString();
    });
 
    rateInput.addEventListener('input', () => {
      rateNum.value = rateInput.value;
    });
    rateNum.addEventListener('input', () => {
      let val = parseFloat(rateNum.value) || 0;
      rateInput.value = Math.max(5, Math.min(20, val)).toString();
    });
 
    tenureInput.addEventListener('input', () => {
      tenureNum.value = tenureInput.value;
    });
    tenureNum.addEventListener('input', () => {
      let val = parseFloat(tenureNum.value) || 0;
      tenureInput.value = Math.max(1, Math.min(30, val)).toString();
    });

    const clampLoanInputs = () => {
      let amt = parseFloat(amountNum.value) || 5000000;
      if (amt < 100000) amt = 100000;
      if (amt > 15000000) amt = 15000000;
      amountNum.value = amt.toString();
      amountInput.value = amt.toString();

      let rate = parseFloat(rateNum.value) || 8.5;
      if (rate < 5) rate = 5;
      if (rate > 20) rate = 20;
      rateNum.value = rate.toString();
      rateInput.value = rate.toString();

      let yrs = parseFloat(tenureNum.value) || 20;
      if (yrs < 1) yrs = 1;
      if (yrs > 30) yrs = 30;
      tenureNum.value = yrs.toString();
      tenureInput.value = yrs.toString();

      calculate();
    };

    [amountNum, rateNum, tenureNum].forEach(input => {
      input.addEventListener('blur', clampLoanInputs);
      input.addEventListener('change', clampLoanInputs);
    });

    function calculate() {
      const rawAmt = parseFloat(amountNum.value) || parseFloat(amountInput.value) || 5000000;
      const P = Math.max(100000, Math.min(15000000, rawAmt));
      const rawRate = parseFloat(rateNum.value) || parseFloat(rateInput.value) || 8.5;
      const annualRate = Math.max(5, Math.min(20, rawRate));
      const rawYears = parseFloat(tenureNum.value) || parseFloat(tenureInput.value) || 20;
      const years = Math.max(1, Math.min(30, rawYears));
      const months = Math.round(years * 12);
 
      const monthlyRate = (annualRate / 12) / 100;

      // EMI Formula: P * r * (1+r)^n / ((1+r)^n - 1)
      let emi = 0;
      if (monthlyRate > 0) {
        emi = P * monthlyRate * Math.pow(1 + monthlyRate, months) / (Math.pow(1 + monthlyRate, months) - 1);
      } else {
        emi = P / months;
      }

      const totalPayment = emi * months;
      const totalInterest = totalPayment - P;

      // Update Card displays
      emiCard.textContent = `₹${Math.round(emi).toLocaleString('en-IN')}`;
      principalCard.textContent = `₹${Math.round(P).toLocaleString('en-IN')}`;
      interestCard.textContent = `₹${Math.round(totalInterest).toLocaleString('en-IN')}`;
      totalCard.textContent = `₹${Math.round(totalPayment).toLocaleString('en-IN')}`;

      // Update Donut Chart
      const principalPct = (P / totalPayment) * 100;
      const interestPct = (totalInterest / totalPayment) * 100;

      const principalStroke = CIRCUMFERENCE * (principalPct / 100);
      const interestStroke = CIRCUMFERENCE * (interestPct / 100);

      donutPrincipal.style.strokeDasharray = `${principalStroke} ${CIRCUMFERENCE}`;
      donutInterest.style.strokeDasharray = `${interestStroke} ${CIRCUMFERENCE}`;

      donutPrincipal.style.strokeDashoffset = '0';
      donutInterest.style.strokeDashoffset = (-principalStroke).toString();

      centerTotalVal.textContent = `₹${Math.round(totalPayment/100000).toLocaleString('en-IN')}L`;

      // Legend texts
      legendPrincipalPct.textContent = `(${Math.round(principalPct)}%)`;
      legendPrincipalVal.textContent = `₹${Math.round(P).toLocaleString('en-IN')}`;

      legendInterestPct.textContent = `(${Math.round(interestPct)}%)`;
      legendInterestVal.textContent = `₹${Math.round(totalInterest).toLocaleString('en-IN')}`;

      // Generate Amortization schedule
      let balance = P;
      const monthlySchedule = [];
      
      for (let m = 1; m <= months; m++) {
        const interestPaid = balance * monthlyRate;
        const principalPaid = emi - interestPaid;
        const endingBalance = Math.max(0, balance - principalPaid);
        
        monthlySchedule.push({
          month: m,
          principalPaid,
          interestPaid,
          endingBalance
        });

        balance = endingBalance;
      }

      // Render schedule based on view setting
      const view = scheduleView.value;
      let html = '';

      if (view === 'monthly') {
        // Show first 12 months
        const limit = Math.min(12, months);
        for (let i = 0; i < limit; i++) {
          const row = monthlySchedule[i];
          html += `
            <tr class="border-b border-hairline hover:bg-canvas-soft-2 font-mono">
              <td class="p-2">Month ${row.month}</td>
              <td class="p-2 text-right">₹${Math.round(row.principalPaid).toLocaleString('en-IN')}</td>
              <td class="p-2 text-right">₹${Math.round(row.interestPaid).toLocaleString('en-IN')}</td>
              <td class="p-2 text-right text-mute">₹${Math.round(row.endingBalance).toLocaleString('en-IN')}</td>
            </tr>
          `;
        }
      } else {
        // Show Yearly summary
        for (let y = 1; y <= years; y++) {
          let yrPrincipal = 0;
          let yrInterest = 0;
          let yrEndingBalance = 0;

          const startMonthIdx = (y - 1) * 12;
          const endMonthIdx = Math.min(y * 12 - 1, months - 1);

          for (let idx = startMonthIdx; idx <= endMonthIdx; idx++) {
            yrPrincipal += monthlySchedule[idx].principalPaid;
            yrInterest += monthlySchedule[idx].interestPaid;
          }
          yrEndingBalance = monthlySchedule[endMonthIdx].endingBalance;

          html += `
            <tr class="border-b border-hairline hover:bg-canvas-soft-2 font-mono">
              <td class="p-2 font-sans font-medium">Year ${y}</td>
              <td class="p-2 text-right">₹${Math.round(yrPrincipal).toLocaleString('en-IN')}</td>
              <td class="p-2 text-right">₹${Math.round(yrInterest).toLocaleString('en-IN')}</td>
              <td class="p-2 text-right text-mute">₹${Math.round(yrEndingBalance).toLocaleString('en-IN')}</td>
            </tr>
          `;
        }
      }

      scheduleBody.innerHTML = html;
    }

    calculate();
  }

  setupLoanCalculator();
  document.addEventListener('astro:page-load', setupLoanCalculator);
</script>
