    <section class="space-y-3 bg-canvas-soft-2 border border-hairline rounded-lg p-6">
      <h3 class="font-sans text-base font-semibold text-ink flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-error"></span>
        2. Medical Disclaimer
