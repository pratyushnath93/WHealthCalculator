---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms & Conditions" activeTab="terms">
  <div class="mb-12">
    <div class="font-mono text-xs uppercase tracking-wider text-mute mb-2">05. Legal</div>
    <h1 class="font-sans text-3xl md:text-5xl font-semibold tracking-tight text-ink leading-none">
      Terms & Conditions
    </h1>
    <p class="text-body text-sm mt-3 max-w-[600px]">
      Last Updated: July 2026. Terms of use and calculation disclaimers.
    </p>
  </div>

  <div class="max-w-[800px] space-y-8 font-sans text-sm text-body leading-relaxed">
    <section class="space-y-3">
      <h2 class="font-sans text-lg font-semibold tracking-tight text-ink">1. Acceptance of Terms</h2>
      <p>
        Welcome to WHealthCalculator.com ("WHealth Calculator", "we", "our", or "us"). These Terms & Conditions ("Terms") govern your access to and use of WHealthCalculator.com, including all calculators, planners, tools, content, features, and related services (collectively, the "Services").
      </p>
