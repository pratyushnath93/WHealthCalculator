---
import Layout from '../../layouts/Layout.astro';
import MetricCard from '../../components/MetricCard.astro';
---

<Layout 
  title="Track Food & Nutrition Log - Meal Tracker & Macro Calculator" 
  description="Log daily meals, track calories, protein, carbs, fat, and micronutrients. Search food database, analyze 7-day nutrition trends, and save recipe templates."
  activeTab="track-food"
>
  <div class="mb-8">
    <div class="font-mono text-xs uppercase tracking-wider text-mute mb-2">01. Health & Nutrition</div>
    <h1 class="font-sans text-3xl md:text-5xl font-semibold tracking-tight text-ink leading-none">
      Track Food & Meal Log
    </h1>
    <p class="text-body text-sm mt-3 max-w-[650px]">
      Log daily meals, monitor macro & micronutrient totals, analyze 7-day nutrition trends, and save your favorite custom meal templates.
    </p>
  </div>

  <!-- Tab Buttons -->
  <div class="flex gap-2 border-b border-hairline mb-6 pb-2 overflow-x-auto">
    <button id="web-tab-all" class="px-4 py-2 text-xs font-semibold rounded-md bg-canvas-soft-2 text-ink border border-hairline cursor-pointer" onclick="switchWebTrackTab('all')">
      1. All Meals Log
    </button>
    <button id="web-tab-insights" class="px-4 py-2 text-xs font-semibold rounded-md text-mute hover:text-ink cursor-pointer" onclick="switchWebTrackTab('insights')">
      2. Nutrition Insights
    </button>
    <button id="web-tab-saved" class="px-4 py-2 text-xs font-semibold rounded-md text-mute hover:text-ink cursor-pointer" onclick="switchWebTrackTab('saved')">
      3. Saved Meals Library
    </button>
  </div>

  <!-- Panel 1: All Meals Log -->
  <div id="web-panel-all" class="space-y-6">
    <!-- Daily Progress & Summary with Date Picker -->
    <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-3 border-b border-hairline">
        <h2 class="font-sans text-lg font-semibold tracking-tight text-ink">Daily Meal Summary Log</h2>
        <div class="flex items-center gap-2">
          <span class="text-sm">📅</span>
          <input type="date" id="web-tf-date" class="border border-hairline bg-canvas text-ink rounded-md px-3 py-1.5 text-xs font-mono font-bold outline-none" onchange="onWebTrackDateChange()" />
          <button type="button" class="px-3 py-1.5 text-xs font-semibold rounded-md bg-canvas-soft-2 text-ink border border-hairline hover:bg-canvas-soft transition-all" onclick="setWebTrackDateToday()">Today</button>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-canvas-soft p-4 border border-hairline rounded-md text-center">
          <span class="font-mono text-[11px] uppercase tracking-wider text-mute block mb-1">Total Calories</span>
          <span id="web-sum-cal" class="font-mono text-xl font-bold text-accent">0 kcal</span>
        </div>
        <div class="bg-canvas-soft p-4 border border-hairline rounded-md text-center">
          <span class="font-mono text-[11px] uppercase tracking-wider text-mute block mb-1">Protein</span>
          <span id="web-sum-prot" class="font-mono text-xl font-bold text-ink">0 g</span>
        </div>
        <div class="bg-canvas-soft p-4 border border-hairline rounded-md text-center">
          <span class="font-mono text-[11px] uppercase tracking-wider text-mute block mb-1">Carbs</span>
          <span id="web-sum-carb" class="font-mono text-xl font-bold text-link">0 g</span>
        </div>
        <div class="bg-canvas-soft p-4 border border-hairline rounded-md text-center">
          <span class="font-mono text-[11px] uppercase tracking-wider text-mute block mb-1">Fat</span>
          <span id="web-sum-fat" class="font-mono text-xl font-bold text-warning">0 g</span>
        </div>
      </div>
    </div>

    <!-- Actions Bar -->
    <div class="flex flex-wrap gap-3">
      <button type="button" id="btn-web-open-add" class="px-4 py-2 text-xs font-semibold rounded-md bg-ink text-canvas hover:opacity-90 transition-all flex items-center gap-1.5 cursor-pointer" onclick="toggleWebTrackForm('add')">
        ➕ Add Food / Drink Item
      </button>
      <button type="button" id="btn-web-open-cat" class="px-4 py-2 text-xs font-semibold rounded-md bg-canvas-soft-2 text-ink border border-hairline hover:bg-canvas-soft transition-all flex items-center gap-1.5 cursor-pointer" onclick="toggleWebTrackForm('cat')">
        🏷 Create Custom Meal Category
      </button>
    </div>

    <!-- Category Creator Box -->
    <div id="form-web-cat-box" class="hidden bg-canvas border border-hairline rounded-lg p-4 shadow-vercel-sm">
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-sans text-sm font-semibold text-ink">Create Custom Meal Category</h3>
        <button type="button" class="text-mute hover:text-ink text-sm font-bold" onclick="toggleWebTrackForm('close')">✕</button>
      </div>
      <div class="flex gap-2">
        <input type="text" id="web-new-cat-input" placeholder="e.g. Pre-Workout, Brunch, Post-Workout Shake" class="flex-grow border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs outline-none focus:border-hairline-strong" />
        <button type="button" class="px-4 py-2 text-xs font-semibold rounded-md bg-ink text-canvas hover:opacity-90" onclick="addWebMealCategory()">+ Create Category</button>
      </div>
    </div>

    <!-- Add Food Form -->
    <div id="form-web-add-box" class="hidden bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-4">
      <div class="flex items-center justify-between pb-3 border-b border-hairline">
        <h3 class="font-sans text-sm font-semibold text-ink">Add Food / Drink Item</h3>
        <button type="button" class="text-mute hover:text-ink text-sm font-bold" onclick="toggleWebTrackForm('close')">✕</button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Meal Category</label>
          <select id="web-add-cat-select" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs outline-none">
            <!-- Dynamic categories -->
          </select>
        </div>

        <div class="relative">
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Food Name (Search Auto-Suggestions)</label>
          <input type="text" id="web-add-food-name" placeholder="Type e.g. Chicken, Oats, Paneer, Eggs, Rice, Apple..." class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs outline-none focus:border-hairline-strong" oninput="onWebFoodSearchInput()" autocomplete="off" />
          <div id="web-search-suggestions" class="hidden absolute top-full left-0 right-0 bg-canvas border border-hairline rounded-md max-h-48 overflow-y-auto z-50 shadow-vercel-md mt-1"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Or Pick from Saved Meals (Optional)</label>
          <select id="web-add-saved-select" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs outline-none" onchange="onWebSelectSavedMeal()">
            <option value="">-- Optional: Select Saved Meal Template --</option>
          </select>
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Portion / Qty</label>
            <input type="number" id="web-add-qty" value="100" min="1" max="2000" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs font-mono outline-none" oninput="calcWebFoodNutritionFromQty()" />
          </div>
          <div>
            <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Unit</label>
            <div id="web-add-unit-label" class="w-full border border-hairline bg-canvas-soft-2 text-ink rounded-md px-3 py-2 text-xs font-mono font-semibold flex items-center justify-center">grams (g)</div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div>
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Calories (kcal)</label>
          <input type="number" id="web-add-cal" placeholder="300" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs font-mono outline-none" />
        </div>
        <div>
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Protein (g)</label>
          <input type="number" id="web-add-prot" placeholder="20" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs font-mono outline-none" />
        </div>
        <div>
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Carbs (g)</label>
          <input type="number" id="web-add-carb" placeholder="35" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs font-mono outline-none" />
        </div>
        <div>
          <label class="font-mono text-xs uppercase tracking-wider text-body block mb-1">Fat (g)</label>
          <input type="number" id="web-add-fat" placeholder="10" class="w-full border border-hairline bg-canvas text-ink rounded-md px-3 py-2 text-xs font-mono outline-none" />
        </div>
      </div>

      <div class="flex flex-wrap gap-2 pt-2">
        <button type="button" class="flex-1 px-4 py-2 text-xs font-semibold rounded-md bg-canvas-soft-2 text-ink border border-hairline hover:bg-canvas-soft" onclick="stageWebFoodItem()">
          ➕ Stage Batch Item
        </button>
        <button type="button" class="flex-1 px-4 py-2 text-xs font-semibold rounded-md bg-ink text-canvas hover:opacity-90" onclick="addWebStagedOrSingleFoodItem()">
          ✔ Add to Meal Log
        </button>
        <button type="button" class="flex-1 px-4 py-2 text-xs font-semibold rounded-md bg-canvas-soft-2 text-link border border-link/30 hover:bg-link/10" onclick="saveWebFoodAsSavedMeal()">
          💾 Save as Recipe Template
        </button>
      </div>

      <!-- Staged Items Box -->
      <div id="web-add-staging-container" class="hidden p-3 border border-hairline rounded-md bg-canvas-soft space-y-2">
        <span class="font-mono text-xs font-semibold text-ink">Staged Batch Items:</span>
        <div id="web-add-staging-list" class="space-y-1.5"></div>
      </div>
    </div>

    <!-- Meal Log List Cards -->
    <div id="web-meals-log-container" class="space-y-4">
      <!-- Dynamic Meal Categories -->
    </div>
  </div>

  <!-- Panel 2: Nutrition Insights -->
  <div id="web-panel-insights" class="hidden space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Donut Macro Split -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-4">
        <h3 class="font-sans text-base font-semibold text-ink border-b border-hairline pb-2">Daily Macro Distribution</h3>
        <div class="flex flex-col sm:flex-row items-center justify-around gap-6 pt-2">
          <div class="relative w-36 h-36">
            <svg class="w-full h-full transform -rotate-90" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="50" stroke="var(--color-hairline)" stroke-width="12" fill="transparent" />
              <circle id="web-donut-carbs" cx="60" cy="60" r="50" stroke="#0070f3" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" />
              <circle id="web-donut-protein" cx="60" cy="60" r="50" stroke="#ff0080" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" />
              <circle id="web-donut-fat" cx="60" cy="60" r="50" stroke="#f9cb28" stroke-width="12" fill="transparent" stroke-dasharray="314.16" stroke-dashoffset="0" />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
              <span class="text-[10px] uppercase font-mono text-mute">Logged</span>
              <span id="web-center-cal" class="font-mono text-sm font-bold text-ink">0 kcal</span>
            </div>
          </div>

          <div class="space-y-2 font-mono text-xs w-full max-w-[200px]">
            <div class="flex items-center justify-between p-1.5 rounded bg-canvas-soft border border-hairline">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-[#0070f3]"></span>
                <span>Carbs <span id="web-carb-pct" class="text-mute">(0%)</span></span>
              </div>
              <span id="web-carb-g" class="font-bold">0g</span>
            </div>
            <div class="flex items-center justify-between p-1.5 rounded bg-canvas-soft border border-hairline">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-[#ff0080]"></span>
                <span>Protein <span id="web-protein-pct" class="text-mute">(0%)</span></span>
              </div>
              <span id="web-protein-g" class="font-bold">0g</span>
            </div>
            <div class="flex items-center justify-between p-1.5 rounded bg-canvas-soft border border-hairline">
              <div class="flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f9cb28]"></span>
                <span>Fat <span id="web-fat-pct" class="text-mute">(0%)</span></span>
              </div>
              <span id="web-fat-g" class="font-bold">0g</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Micronutrient Breakdown Grid -->
      <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-4">
        <h3 class="font-sans text-base font-semibold text-ink border-b border-hairline pb-2">Estimated Micronutrients Breakdown</h3>
        <div id="web-micros-grid" class="grid grid-cols-2 gap-3 font-mono text-xs text-mute pt-2">
          <!-- Dynamic micros -->
        </div>
      </div>
    </div>

    <!-- Last 7 Days Nutrition Trends Card -->
    <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-4">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-hairline pb-3">
        <h3 class="font-sans text-base font-semibold text-ink">Last 7 Days Nutrition Trends</h3>
        <select id="web-trend-nutrient-select" class="border border-hairline bg-canvas text-ink rounded-md px-3 py-1.5 text-xs font-mono outline-none" onchange="renderWeb7DayTrendsChart()">
          <option value="cal" selected>Calories (kcal)</option>
          <option value="prot">Protein (g)</option>
          <option value="carb">Carbohydrates (g)</option>
          <option value="fat">Fat (g)</option>
          <option value="fiber">Fibre (g)</option>
        </select>
      </div>
      <div id="web-trends-chart-container" class="w-full min-h-[220px] pt-2">
        <!-- SVG bar chart rendered dynamically -->
      </div>
    </div>
  </div>

  <!-- Panel 3: Saved Meals Library -->
  <div id="web-panel-saved" class="hidden space-y-6">
    <div class="bg-canvas border border-hairline rounded-lg p-6 shadow-vercel-sm space-y-4">
      <h3 class="font-sans text-base font-semibold text-ink border-b border-hairline pb-2">Your Saved Meals & Recipe Templates</h3>
      <div id="web-saved-meals-list" class="space-y-4 pt-2">
        <!-- Dynamic saved meals -->
      </div>
    </div>
  </div>

  <!-- Disclaimer Footer -->
  <p class="text-[10px] text-mute text-center leading-relaxed mt-12 mb-6">
    * Health calculations are estimates and are not a substitute for medical or nutritional advice. Please consult a licensed doctor or registered dietitian before making health or dietary decisions.
  </p>
</Layout>

<script is:inline>
  // Food Database
  const WEB_FOOD_DB = [
    { name: "Chicken Breast (Cooked)", cal: 165, prot: 31, carb: 0, fat: 3.6, fiber: 0, calcium: 15, iron: 1, unit: "grams (g)" },
    { name: "Oats (Raw)", cal: 389, prot: 16.9, carb: 66.3, fat: 6.9, fiber: 10.6, calcium: 54, iron: 4.7, unit: "grams (g)" },
    { name: "Paneer (Cottage Cheese)", cal: 265, prot: 18.3, carb: 1.2, fat: 20.8, fiber: 0, calcium: 480, iron: 0.2, unit: "grams (g)" },
    { name: "Whole Eggs (Boiled)", cal: 155, prot: 12.6, carb: 1.1, fat: 10.6, fiber: 0, calcium: 50, iron: 1.2, unit: "grams (g)" },
    { name: "White Rice (Cooked)", cal: 130, prot: 2.7, carb: 28.2, fat: 0.3, fiber: 0.4, calcium: 10, iron: 0.2, unit: "grams (g)" },
    { name: "Brown Rice (Cooked)", cal: 111, prot: 2.6, carb: 23, fat: 0.9, fiber: 1.8, calcium: 10, iron: 0.4, unit: "grams (g)" },
    { name: "Wheat Roti / Chapati", cal: 120, prot: 3.1, carb: 22.4, fat: 2.2, fiber: 2.8, calcium: 12, iron: 0.9, unit: "pieces" },
    { name: "Yellow Toor Dal (Cooked)", cal: 116, prot: 6.8, carb: 19.8, fat: 1.2, fiber: 3.5, calcium: 24, iron: 1.1, unit: "grams (g)" },
    { name: "Whey Protein Isolate", cal: 120, prot: 25, carb: 1.5, fat: 1, fiber: 0, calcium: 120, iron: 0.5, unit: "scoop (30g)" },
    { name: "Apple", cal: 52, prot: 0.3, carb: 13.8, fat: 0.2, fiber: 2.4, calcium: 6, iron: 0.1, unit: "medium fruit" },
    { name: "Banana", cal: 89, prot: 1.1, carb: 22.8, fat: 0.3, fiber: 2.6, calcium: 5, iron: 0.3, unit: "medium fruit" },
    { name: "Almonds (Raw)", cal: 579, prot: 21.2, carb: 21.7, fat: 49.9, fiber: 12.5, calcium: 269, iron: 3.7, unit: "grams (g)" },
    { name: "Whole Milk (Cow)", cal: 61, prot: 3.2, carb: 4.8, fat: 3.3, fiber: 0, calcium: 113, iron: 0.1, unit: "ml" },
    { name: "Greek Yogurt", cal: 59, prot: 10, carb: 3.6, fat: 0.4, fiber: 0, calcium: 110, iron: 0.1, unit: "grams (g)" },
    { name: "Salmon (Cooked)", cal: 206, prot: 22.1, carb: 0, fat: 12.3, fiber: 0, calcium: 12, iron: 0.8, unit: "grams (g)" },
    { name: "Broccoli (Steam)", cal: 35, prot: 2.4, carb: 7.2, fat: 0.4, fiber: 3.3, calcium: 47, iron: 0.7, unit: "grams (g)" }
  ];

  let webTrackDate = new Date().toISOString().split('T')[0];
  let webMealCategories = ["Breakfast", "Lunch", "Dinner", "Snacks"];
  let webLogs = JSON.parse(localStorage.getItem('whealth_web_food_logs') || '{}');
  let webSavedMeals = JSON.parse(localStorage.getItem('whealth_web_saved_meals') || '[]');
  let webStagedItems = [];
  let webSelectedFoodItem = null;

  function initWebTrackFood() {
    document.getElementById('web-tf-date').value = webTrackDate;
    updateWebCategoryDropdowns();
    renderWebLogs();
    renderWebSavedMeals();
  }

  function setWebTrackDateToday() {
    webTrackDate = new Date().toISOString().split('T')[0];
    document.getElementById('web-tf-date').value = webTrackDate;
    renderWebLogs();
  }

  function onWebTrackDateChange() {
    webTrackDate = document.getElementById('web-tf-date').value || new Date().toISOString().split('T')[0];
    renderWebLogs();
  }

  function switchWebTrackTab(tab) {
    ['all', 'insights', 'saved'].forEach(t => {
      const btn = document.getElementById('web-tab-' + t);
      const panel = document.getElementById('web-panel-' + t);
      if (t === tab) {
        btn.className = "px-4 py-2 text-xs font-semibold rounded-md bg-canvas-soft-2 text-ink border border-hairline cursor-pointer";
        panel.classList.remove('hidden');
      } else {
        btn.className = "px-4 py-2 text-xs font-semibold rounded-md text-mute hover:text-ink cursor-pointer";
        panel.classList.add('hidden');
      }
    });
    if (tab === 'insights') renderWebInsights();
    if (tab === 'saved') renderWebSavedMeals();
  }

  function toggleWebTrackForm(type) {
    const addBox = document.getElementById('form-web-add-box');
    const catBox = document.getElementById('form-web-cat-box');
    if (type === 'add') {
      addBox.classList.toggle('hidden');
      catBox.classList.add('hidden');
    } else if (type === 'cat') {
      catBox.classList.toggle('hidden');
      addBox.classList.add('hidden');
    } else {
      addBox.classList.add('hidden');
      catBox.classList.add('hidden');
    }
  }

  function updateWebCategoryDropdowns() {
    const select = document.getElementById('web-add-cat-select');
    select.innerHTML = webMealCategories.map(c => `<option value="${c}">${c}</option>`).join('');
  }

  function addWebMealCategory() {
    const name = document.getElementById('web-new-cat-input').value.trim();
    if (!name) return;
    if (!webMealCategories.includes(name)) {
      webMealCategories.push(name);
      updateWebCategoryDropdowns();
      renderWebLogs();
    }
    document.getElementById('web-new-cat-input').value = '';
    toggleWebTrackForm('close');
  }

  function onWebFoodSearchInput() {
    const query = document.getElementById('web-add-food-name').value.toLowerCase().trim();
    const suggestionsBox = document.getElementById('web-search-suggestions');
    if (!query) {
      suggestionsBox.classList.add('hidden');
      return;
    }

    const matches = WEB_FOOD_DB.filter(f => f.name.toLowerCase().includes(query));
    if (matches.length === 0) {
      suggestionsBox.classList.add('hidden');
      return;
    }

    suggestionsBox.innerHTML = matches.map(f => `
      <div class="p-2 border-b border-hairline hover:bg-canvas-soft cursor-pointer flex justify-between items-center text-xs" onclick="selectWebFoodItem('${f.name}')">
        <span class="font-medium text-ink">${f.name}</span>
        <span class="font-mono text-[10px] text-mute">${f.cal} kcal / 100g</span>
      </div>
    `).join('');
    suggestionsBox.classList.remove('hidden');
  }

  function selectWebFoodItem(name) {
    const item = WEB_FOOD_DB.find(f => f.name === name);
    if (!item) return;
    webSelectedFoodItem = item;
    document.getElementById('web-add-food-name').value = item.name;
    document.getElementById('web-add-unit-label').innerText = item.unit || 'grams (g)';
    document.getElementById('web-search-suggestions').classList.add('hidden');
    calcWebFoodNutritionFromQty();
  }

  function calcWebFoodNutritionFromQty() {
    if (!webSelectedFoodItem) return;
    const qty = parseFloat(document.getElementById('web-add-qty').value) || 100;
    const ratio = qty / 100;
    document.getElementById('web-add-cal').value = Math.round(webSelectedFoodItem.cal * ratio);
    document.getElementById('web-add-prot').value = Math.round(webSelectedFoodItem.prot * ratio);
    document.getElementById('web-add-carb').value = Math.round(webSelectedFoodItem.carb * ratio);
    document.getElementById('web-add-fat').value = Math.round(webSelectedFoodItem.fat * ratio);
  }

  function stageWebFoodItem() {
    const name = document.getElementById('web-add-food-name').value.trim();
    if (!name) return;
    const item = {
      name,
      qty: parseFloat(document.getElementById('web-add-qty').value) || 100,
      unit: document.getElementById('web-add-unit-label').innerText,
      cal: parseFloat(document.getElementById('web-add-cal').value) || 0,
      prot: parseFloat(document.getElementById('web-add-prot').value) || 0,
      carb: parseFloat(document.getElementById('web-add-carb').value) || 0,
      fat: parseFloat(document.getElementById('web-add-fat').value) || 0
    };
    webStagedItems.push(item);
    renderWebStagedItems();
  }

  function renderWebStagedItems() {
    const container = document.getElementById('web-add-staging-container');
    const list = document.getElementById('web-add-staging-list');
    if (webStagedItems.length === 0) {
      container.classList.add('hidden');
      return;
    }
    container.classList.remove('hidden');
    list.innerHTML = webStagedItems.map((item, idx) => `
      <div class="flex justify-between items-center text-xs p-1.5 bg-canvas rounded border border-hairline">
        <span>${item.name} (${item.qty}) — ${item.cal} kcal</span>
        <button class="text-warning text-xs font-bold" onclick="removeWebStagedItem(${idx})">✕</button>
      </div>
    `).join('');
  }

  function removeWebStagedItem(idx) {
    webStagedItems.splice(idx, 1);
    renderWebStagedItems();
  }

  function addWebStagedOrSingleFoodItem() {
    const category = document.getElementById('web-add-cat-select').value;
    if (!webLogs[webTrackDate]) webLogs[webTrackDate] = {};
    if (!webLogs[webTrackDate][category]) webLogs[webTrackDate][category] = [];

    if (webStagedItems.length > 0) {
      webLogs[webTrackDate][category].push(...webStagedItems);
      webStagedItems = [];
      renderWebStagedItems();
    } else {
      const name = document.getElementById('web-add-food-name').value.trim();
      if (!name) return;
      webLogs[webTrackDate][category].push({
        name,
        qty: parseFloat(document.getElementById('web-add-qty').value) || 100,
        unit: document.getElementById('web-add-unit-label').innerText,
        cal: parseFloat(document.getElementById('web-add-cal').value) || 0,
        prot: parseFloat(document.getElementById('web-add-prot').value) || 0,
        carb: parseFloat(document.getElementById('web-add-carb').value) || 0,
        fat: parseFloat(document.getElementById('web-add-fat').value) || 0
      });
    }

    localStorage.setItem('whealth_web_food_logs', JSON.stringify(webLogs));
    renderWebLogs();
    toggleWebTrackForm('close');
  }

  function renderWebLogs() {
    const dayData = webLogs[webTrackDate] || {};
    let totalCal = 0, totalProt = 0, totalCarb = 0, totalFat = 0;

    const container = document.getElementById('web-meals-log-container');
    container.innerHTML = webMealCategories.map(cat => {
      const items = dayData[cat] || [];
      let catCal = 0, catProt = 0, catCarb = 0, catFat = 0;
      items.forEach(i => {
        catCal += i.cal; catProt += i.prot; catCarb += i.carb; catFat += i.fat;
      });
      totalCal += catCal; totalProt += catProt; totalCarb += catCarb; totalFat += catFat;

      return `
        <div class="bg-canvas border border-hairline rounded-lg p-5 shadow-vercel-sm space-y-3">
          <div class="flex justify-between items-center pb-2 border-b border-hairline">
            <h3 class="font-sans text-sm font-semibold text-ink">${cat}</h3>
            <span class="font-mono text-xs text-mute">${catCal} kcal | P: ${catProt}g | C: ${catCarb}g | F: ${catFat}g</span>
          </div>
          ${items.length === 0 ? '<p class="text-xs text-mute italic">No items logged for this category.</p>' : `
            <div class="space-y-2">
              ${items.map((i, idx) => `
                <div class="flex justify-between items-center text-xs p-2 bg-canvas-soft rounded border border-hairline">
                  <div>
                    <span class="font-medium text-ink">${i.name}</span>
                    <span class="text-mute font-mono ml-2">(${i.qty} ${i.unit || 'g'})</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="font-mono text-mute">${i.cal} kcal</span>
                    <button class="text-warning text-xs font-bold hover:opacity-80" onclick="deleteWebLogItem('${cat}', ${idx})">✕</button>
                  </div>
                </div>
              `).join('')}
            </div>
          `}
        </div>
      `;
    }).join('');

    document.getElementById('web-sum-cal').innerText = `${totalCal} kcal`;
    document.getElementById('web-sum-prot').innerText = `${totalProt} g`;
    document.getElementById('web-sum-carb').innerText = `${totalCarb} g`;
    document.getElementById('web-sum-fat').innerText = `${totalFat} g`;
  }

  function deleteWebLogItem(cat, idx) {
    if (webLogs[webTrackDate] && webLogs[webTrackDate][cat]) {
      webLogs[webTrackDate][cat].splice(idx, 1);
      localStorage.setItem('whealth_web_food_logs', JSON.stringify(webLogs));
      renderWebLogs();
    }
  }

  function saveWebFoodAsSavedMeal() {
    const name = prompt("Enter a name for this saved meal recipe:");
    if (!name) return;
    const currentItems = webStagedItems.length > 0 ? [...webStagedItems] : [{
      name: document.getElementById('web-add-food-name').value.trim() || 'Custom Recipe',
      qty: parseFloat(document.getElementById('web-add-qty').value) || 100,
      unit: document.getElementById('web-add-unit-label').innerText,
      cal: parseFloat(document.getElementById('web-add-cal').value) || 0,
      prot: parseFloat(document.getElementById('web-add-prot').value) || 0,
      carb: parseFloat(document.getElementById('web-add-carb').value) || 0,
      fat: parseFloat(document.getElementById('web-add-fat').value) || 0
    }];

    webSavedMeals.push({ name, items: currentItems });
    localStorage.setItem('whealth_web_saved_meals', JSON.stringify(webSavedMeals));
    renderWebSavedMeals();
    alert(`Saved "${name}" to your Saved Meals Library!`);
  }

  function renderWebSavedMeals() {
    const list = document.getElementById('web-saved-meals-list');
    const select = document.getElementById('web-add-saved-select');

    select.innerHTML = '<option value="">-- Optional: Select Saved Meal Template --</option>' + webSavedMeals.map((m, idx) => `
      <option value="${idx}">${m.name}</option>
    `).join('');

    if (webSavedMeals.length === 0) {
      list.innerHTML = '<p class="text-xs text-mute italic">No saved meals in your library yet. Save custom recipes from the Add Food section!</p>';
      return;
    }

    list.innerHTML = webSavedMeals.map((m, idx) => {
      let totCal = 0, totP = 0, totC = 0, totF = 0;
      m.items.forEach(i => { totCal += i.cal; totP += i.prot; totC += i.carb; totF += i.fat; });
      return `
        <div class="bg-canvas-soft border border-hairline rounded-lg p-4 space-y-3">
          <div class="flex justify-between items-center">
            <h4 class="font-sans text-sm font-semibold text-ink">${m.name}</h4>
            <div class="flex items-center gap-2">
              <span class="font-mono text-xs text-mute">${totCal} kcal | P:${totP}g C:${totC}g F:${totF}g</span>
              <button class="text-warning text-xs font-bold ml-2" onclick="deleteWebSavedMeal(${idx})">✕ Delete</button>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 text-xs">
            ${m.items.map(i => `<span class="bg-canvas border border-hairline px-2 py-1 rounded text-mute font-mono">${i.name} (${i.qty})</span>`).join('')}
          </div>
          <button class="w-full py-1.5 text-xs font-semibold rounded bg-ink text-canvas hover:opacity-90" onclick="logWebSavedMealDirect(${idx})">+ Add Meal to Daily Log</button>
        </div>
      `;
    }).join('');
  }

  function onWebSelectSavedMeal() {
    const idx = document.getElementById('web-add-saved-select').value;
    if (idx === '') return;
    const meal = webSavedMeals[idx];
    if (!meal) return;
    webStagedItems = [...meal.items];
    renderWebStagedItems();
  }

  function logWebSavedMealDirect(idx) {
    const meal = webSavedMeals[idx];
    if (!meal) return;
    const category = prompt("Which category to add to? (Breakfast, Lunch, Dinner, Snacks):", "Breakfast") || "Breakfast";
    if (!webLogs[webTrackDate]) webLogs[webTrackDate] = {};
    if (!webLogs[webTrackDate][category]) webLogs[webTrackDate][category] = [];
    webLogs[webTrackDate][category].push(...meal.items);
    localStorage.setItem('whealth_web_food_logs', JSON.stringify(webLogs));
    renderWebLogs();
    alert(`Logged "${meal.name}" to ${category}!`);
  }

  function deleteWebSavedMeal(idx) {
    webSavedMeals.splice(idx, 1);
    localStorage.setItem('whealth_web_saved_meals', JSON.stringify(webSavedMeals));
    renderWebSavedMeals();
  }

  function renderWebInsights() {
    const dayData = webLogs[webTrackDate] || {};
    let totalCal = 0, totalProt = 0, totalCarb = 0, totalFat = 0;
    Object.values(dayData).forEach(items => {
      items.forEach(i => { totalCal += i.cal; totalProt += i.prot; totalCarb += i.carb; totalFat += i.fat; });
    });

    document.getElementById('web-center-cal').innerText = `${totalCal} kcal`;
    document.getElementById('web-protein-g').innerText = `${totalProt}g`;
    document.getElementById('web-carb-g').innerText = `${totalCarb}g`;
    document.getElementById('web-fat-g').innerText = `${totalFat}g`;

    const totalG = totalProt + totalCarb + totalFat || 1;
    const pPct = Math.round((totalProt / totalG) * 100);
    const cPct = Math.round((totalCarb / totalG) * 100);
    const fPct = Math.round((totalFat / totalG) * 100);

    document.getElementById('web-protein-pct').innerText = `(${pPct}%)`;
    document.getElementById('web-carb-pct').innerText = `(${cPct}%)`;
    document.getElementById('web-fat-pct').innerText = `(${fPct}%)`;

    // Micronutrients breakdown
    const micros = [
      { name: "Dietary Fibre", val: Math.round(totalCarb * 0.12) + " g" },
      { name: "Calcium", val: Math.round(totalProt * 14 + 150) + " mg" },
      { name: "Iron", val: Math.round(totalProt * 0.15 + 2) + " mg" },
      { name: "Potassium", val: Math.round(totalCal * 0.9) + " mg" },
      { name: "Sodium", val: Math.round(totalCal * 0.8) + " mg" },
      { name: "Vitamin A", val: "450 mcg" },
      { name: "Vitamin C", val: "65 mg" },
      { name: "Vitamin D", val: "10 mcg" }
    ];
    document.getElementById('web-micros-grid').innerHTML = micros.map(m => `
      <div class="flex justify-between p-2 rounded bg-canvas-soft border border-hairline">
        <span>${m.name}</span>
        <span class="font-bold text-ink">${m.val}</span>
      </div>
    `).join('');

    renderWeb7DayTrendsChart();
  }

  function renderWeb7DayTrendsChart() {
    const metric = document.getElementById('web-trend-nutrient-select').value;
    const container = document.getElementById('web-trends-chart-container');
    const days = [];
    for (let i = 6; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      const dateStr = d.toISOString().split('T')[0];
      const dayLogs = webLogs[dateStr] || {};
      let val = 0;
      Object.values(dayLogs).forEach(items => {
        items.forEach(item => {
          if (metric === 'cal') val += item.cal;
          if (metric === 'prot') val += item.prot;
          if (metric === 'carb') val += item.carb;
          if (metric === 'fat') val += item.fat;
          if (metric === 'fiber') val += Math.round(item.carb * 0.12);
        });
      });
      days.push({ label: d.toLocaleDateString('en-US', { weekday: 'short' }), val, dateStr });
    }

    const maxVal = Math.max(...days.map(d => d.val), 10);
    const svgWidth = 600, svgHeight = 180;
    const barWidth = 40, gap = 35;

    const barsSVG = days.map((d, idx) => {
      const h = Math.max(10, Math.round((d.val / maxVal) * 120));
      const x = 50 + idx * (barWidth + gap);
      const y = 140 - h;
      const isToday = d.dateStr === webTrackDate;
      const color = isToday ? "#0070f3" : "var(--color-hairline-strong)";
      return `
        <rect x="${x}" y="${y}" width="${barWidth}" height="${h}" rx="4" fill="${color}" />
        <text x="${x + barWidth / 2}" y="${y - 8}" text-anchor="middle" font-size="10" font-family="monospace" fill="var(--color-ink)" font-weight="bold">${d.val}</text>
        <text x="${x + barWidth / 2}" y="160" text-anchor="middle" font-size="11" font-family="sans-serif" fill="var(--color-mute)">${d.label}</text>
      `;
    }).join('');

    container.innerHTML = `
      <svg viewBox="0 0 ${svgWidth} ${svgHeight}" class="w-full h-auto">
        <line x1="30" y1="140" x2="570" y2="140" stroke="var(--color-hairline)" stroke-width="1" />
        ${barsSVG}
      </svg>
    `;
  }

  document.addEventListener('DOMContentLoaded', initWebTrackFood);
</script>
