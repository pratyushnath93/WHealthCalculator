---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeTab?: 'health' | 'sip' | 'swp' | 'retirement' | 'loans' | 'risk' | 'home' | 'about' | 'contact' | 'privacy' | 'terms' | 'faq';
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const { 
  title, 
  description = 'Calculators for health parameters and financial decisions.', 
  activeTab = 'home',
  ogTitle,
  ogDescription,
  ogType,
  canonicalUrl
} = Astro.props;
const isWealthActive = ['sip', 'swp', 'retirement', 'loans', 'risk'].includes(activeTab);
const isHealthActive = activeTab === 'health';
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YCG8JF5SKM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-YCG8JF5SKM');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — WHealth Calculator</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="WHealth" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl || `https://whealthcalculator.com${Astro.url.pathname}`} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType || "website"} />
    <meta property="og:url" content={canonicalUrl || `https://whealthcalculator.com${Astro.url.pathname}`} />
    <meta property="og:title" content={ogTitle || `${title} — WHealth Calculator`} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:image" content="https://whealthcalculator.com/og-image.png" />
    <meta property="og:site_name" content="WHealth Calculator" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl || `https://whealthcalculator.com${Astro.url.pathname}`} />
    <meta property="twitter:title" content={ogTitle || `${title} — WHealth Calculator`} />
    <meta property="twitter:description" content={ogDescription || description} />
    <meta property="twitter:image" content="https://whealthcalculator.com/og-image.png" />
    
    <!-- Google Fonts: Inter for Sans, JetBrains Mono for Technical Labels -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Blocking dark mode initialization to prevent flash -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-canvas-soft text-ink min-h-screen flex flex-col antialiased">
    <!-- Sticky Navigation Bar -->
    <header class="sticky top-0 z-50 bg-canvas/80 backdrop-blur-md border-b border-hairline h-16 flex items-center px-6 md:px-12 justify-between">
      <div class="flex items-center gap-8">
        <a href="/" class="font-sans font-semibold text-lg tracking-tight hover:opacity-80 transition-opacity">
          WHealth <span class="text-link">Calculator</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          <!-- Health Planners Dropdown Menu -->
          <div class="relative group">
            <button 
              class={`px-3 py-1.5 rounded-full text-sm font-medium transition-all flex items-center gap-1 cursor-pointer ${activeTab === 'health' ? 'bg-primary text-on-primary shadow-vercel-sm font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
            >
              <span>Health Planners</span>
              <svg class="w-3.5 h-3.5 text-current transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <div class="absolute left-0 mt-1.5 w-60 rounded-md bg-canvas border border-hairline shadow-vercel-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50 p-1.5 backdrop-blur-md">
              <a 
                href="/health" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'health' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Health Metrices & Diet Planner
              </a>
              <a 
                href="/health/track-food" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'track-food' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Track Food & Meal Log
              </a>
            </div>
          </div>

          <!-- Wealth & Finance Dropdown Menu -->
          <div class="relative group">
            <button 
              class={`px-3 py-1.5 rounded-full text-sm font-medium transition-all flex items-center gap-1 cursor-pointer ${isWealthActive ? 'bg-primary text-on-primary shadow-vercel-sm font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
            >
              <span>Wealth & Finance</span>
              <svg class="w-3.5 h-3.5 text-current transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            
            <div class="absolute left-0 mt-1.5 w-60 rounded-md bg-canvas border border-hairline shadow-vercel-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50 p-1.5 backdrop-blur-md">
              <a 
                href="/finance/loans" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'loans' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                EMI Calculator
              </a>
              <a 
                href="/finance/sip" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'sip' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                SIP Calculator
              </a>
              <a 
                href="/finance/swp" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'swp' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                SWP Calculator
              </a>
              <a 
                href="/finance/retirement" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'retirement' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Retirement Calculator
              </a>
              <a 
                href="/finance/risk-allocation" 
                class={`flex items-center px-3 py-2 rounded text-xs font-medium transition-colors ${activeTab === 'risk' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Financial Portfolio Planner
              </a>
            </div>
          </div>
        </nav>
      </div>
      
      <!-- Mobile navigation button / Header CTA -->
      <div class="flex items-center gap-2">
        <button 
          id="theme-toggle" 
          class="w-8 h-8 rounded-md border border-hairline bg-canvas flex items-center justify-center text-body hover:bg-canvas-soft-2 hover:text-ink cursor-pointer transition-all shadow-vercel-sm"
          aria-label="Toggle dark mode"
        >
          <!-- Sun Icon (visible in dark mode) -->
          <svg id="sun-icon" class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4"></circle>
            <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
          </svg>
          <!-- Moon Icon (visible in light mode) -->
          <svg id="moon-icon" class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
        <button 
          id="mobile-menu-toggle" 
          class="md:hidden w-8 h-8 rounded-md border border-hairline bg-canvas flex items-center justify-center text-body hover:bg-canvas-soft-2 hover:text-ink cursor-pointer transition-all shadow-vercel-sm"
          aria-label="Open navigation menu"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile Drawer Overlay -->
    <div 
      id="mobile-drawer-overlay" 
      class="fixed inset-0 z-50 bg-canvas-soft/80 backdrop-blur-sm hidden transition-all duration-300 opacity-0"
    >
      <div 
        id="mobile-drawer" 
        class="fixed top-0 right-0 bottom-0 w-80 bg-canvas border-l border-hairline p-6 shadow-vercel-lg transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
      >
        <div class="flex items-center justify-between mb-8">
          <span class="font-sans font-semibold text-base tracking-tight text-ink">WHealth Menu</span>
          <button 
            id="mobile-drawer-close" 
            class="w-8 h-8 rounded-md border border-hairline bg-canvas flex items-center justify-center text-body hover:bg-canvas-soft-2 hover:text-ink cursor-pointer transition-all shadow-vercel-sm"
            aria-label="Close menu"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <nav class="flex-1 flex flex-col gap-6">
          <div class="space-y-3">
            <div class="font-mono text-[10px] text-mute uppercase tracking-widest">Health Planners</div>
            <a 
              href="/health" 
              class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'health' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
            >
              Health Metrices & Diet Planner
            </a>
          </div>

          <div class="space-y-3">
            <div class="font-mono text-[10px] text-mute uppercase tracking-widest">Wealth & Finance</div>
            <div class="flex flex-col gap-1 pl-2 border-l border-hairline">
              <a 
                href="/finance/loans" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'loans' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                EMI Calculator
              </a>
              <a 
                href="/finance/sip" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'sip' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                SIP Calculator
              </a>
              <a 
                href="/finance/swp" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'swp' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                SWP Calculator
              </a>
              <a 
                href="/finance/retirement" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'retirement' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Retirement Planner
              </a>
              <a 
                href="/finance/risk-allocation" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'risk' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Financial Portfolio Planner
              </a>
            </div>
          </div>

          <div class="space-y-3">
            <div class="font-mono text-[10px] text-mute uppercase tracking-widest">Company</div>
            <div class="flex flex-col gap-1 pl-2 border-l border-hairline">
              <a 
                href="/about" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'about' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                About Us
              </a>
              <a 
                href="/contact" 
                class={`block px-3 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'contact' ? 'bg-primary/10 text-primary font-semibold' : 'text-body hover:bg-canvas-soft-2 hover:text-ink'}`}
              >
                Contact Us
              </a>
            </div>
          </div>
        </nav>

        <div class="pt-6 border-t border-hairline">
          <p class="text-[10px] text-mute font-mono">© 2026 WHealth Calculator</p>
        </div>
      </div>
    </div>

    <!-- Main Content Area -->
    <main class="flex-1 w-full max-w-[1400px] mx-auto px-6 py-12 md:px-12 flex flex-col">
      {activeTab !== 'home' && (
        <div class="flex items-center gap-2 mb-8 print:hidden">
          <button 
            id="nav-back-btn"
            class="hidden w-8 h-8 rounded border border-hairline bg-canvas flex items-center justify-center text-body hover:text-ink hover:bg-canvas-soft-2 transition-all shadow-vercel-sm cursor-pointer"
            title="Go back"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <button 
            id="nav-forward-btn"
            class="hidden w-8 h-8 rounded border border-hairline bg-canvas flex items-center justify-center text-body hover:text-ink hover:bg-canvas-soft-2 transition-all shadow-vercel-sm cursor-pointer"
            title="Go forward"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      )}
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-hairline bg-canvas py-12 px-6 md:px-12">
      <div class="max-w-[1400px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <div class="font-sans font-semibold text-ink tracking-tight mb-4">WHealth <span class="text-link">Calculator</span></div>
          <p class="text-mute text-xs max-w-[240px] leading-relaxed">
            Precise parameter tools designed for health tracking and structured financial planning.
          </p>
        </div>
        <div>
          <div class="font-mono text-xs text-body uppercase tracking-wider mb-4">Health & Fitness</div>
          <ul class="space-y-2 text-sm">
            <li><a href="/health" class="text-body hover:text-ink transition-colors">Health Metrices & Diet Planner</a></li>
          </ul>
        </div>
        <div>
          <div class="font-mono text-xs text-body uppercase tracking-wider mb-4">Wealth & Finance</div>
          <ul class="space-y-2 text-sm">
            <li><a href="/finance/loans" class="text-body hover:text-ink transition-colors">EMI Calculator</a></li>
            <li><a href="/finance/sip" class="text-body hover:text-ink transition-colors">SIP Calculator</a></li>
            <li><a href="/finance/swp" class="text-body hover:text-ink transition-colors">SWP Calculator</a></li>
            <li><a href="/finance/retirement" class="text-body hover:text-ink transition-colors">Retirement Planner</a></li>
            <li><a href="/finance/risk-allocation" class="text-body hover:text-ink transition-colors">Financial Portfolio Planner</a></li>
          </ul>
        </div>
        <div>
          <div class="font-mono text-xs text-body uppercase tracking-wider mb-4">Company & Legal</div>
          <ul class="space-y-2 text-sm">
            <li><a href="/about" class="text-body hover:text-ink transition-colors font-sans">About Us</a></li>
            <li><a href="/contact" class="text-body hover:text-ink transition-colors font-sans">Contact Us</a></li>
            <li><a href="/faq" class="text-body hover:text-ink transition-colors font-sans">FAQ</a></li>
            <li><a href="/privacy" class="text-body hover:text-ink transition-colors font-sans">Privacy Policy</a></li>
            <li><a href="/terms" class="text-body hover:text-ink transition-colors font-sans">Terms & Conditions</a></li>
          </ul>
        </div>
      </div>
      <div class="max-w-[1400px] mx-auto mt-12 pt-6 border-t border-hairline flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-mute text-xs font-mono">© 2026 WHealth Calculator. All calculations are illustrative.</p>
      </div>
    </footer>

    <!-- Theme Toggle Event Handler -->
    <script>
      function setupThemeToggle() {
        const toggle = document.getElementById('theme-toggle');
        if (!toggle) return;
        
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          window.dispatchEvent(new Event('theme-change'));
        });
      }
      
      function setupMobileMenu() {
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const menuClose = document.getElementById('mobile-drawer-close');
        const overlay = document.getElementById('mobile-drawer-overlay');
        const drawer = document.getElementById('mobile-drawer');
        if (!menuToggle || !menuClose || !overlay || !drawer) return;

        function openMenu() {
          if (!overlay || !drawer) return;
          overlay.classList.remove('hidden');
          // Force layout reflow
          void overlay.offsetHeight;
          overlay.classList.add('opacity-100');
          drawer.classList.remove('translate-x-full');
          document.body.classList.add('overflow-hidden');
        }

        function closeMenu() {
          if (!overlay || !drawer) return;
          overlay.classList.remove('opacity-100');
          drawer.classList.add('translate-x-full');
          document.body.classList.remove('overflow-hidden');
          setTimeout(() => {
            if (!overlay) return;
            if (!overlay.classList.contains('opacity-100')) {
              overlay.classList.add('hidden');
            }
          }, 300);
        }

        menuToggle.addEventListener('click', openMenu);
        menuClose.addEventListener('click', closeMenu);
        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) {
            closeMenu();
          }
        });
        
        // Close menu on link click (important for anchor navigation)
        const links = drawer.querySelectorAll('a');
        links.forEach(link => {
          link.addEventListener('click', closeMenu);
        });
      }

      function setupHistoryNavigation() {
        const backBtn = document.getElementById('nav-back-btn');
        const forwardBtn = document.getElementById('nav-forward-btn');
        if (!backBtn || !forwardBtn) return;

        function updateButtons() {
          if (!backBtn || !forwardBtn) return;
          // Check if we can go back
          let canGoBack = false;
          if (window.navigation && typeof window.navigation.canGoBack === 'boolean') {
            canGoBack = window.navigation.canGoBack;
          } else {
            canGoBack = window.history.length > 1 && document.referrer !== '';
          }

          // Check if we can go forward
          let canGoForward = false;
          if (window.navigation && typeof window.navigation.canGoForward === 'boolean') {
            canGoForward = window.navigation.canGoForward;
          } else {
            canGoForward = sessionStorage.getItem('navigated-back') === 'true';
          }

          // Toggle class states
          if (canGoBack) {
            backBtn.classList.remove('hidden');
          } else {
            backBtn.classList.add('hidden');
          }

          if (canGoForward) {
            forwardBtn.classList.remove('hidden');
          } else {
            forwardBtn.classList.add('hidden');
          }
        }

        // Add history popstate triggers
        backBtn.addEventListener('click', () => {
          sessionStorage.setItem('navigated-back', 'true');
          window.history.back();
        });

        forwardBtn.addEventListener('click', () => {
          sessionStorage.removeItem('navigated-back');
          window.history.forward();
        });

        // Listen for standard navigation changes to reset forward cache
        window.addEventListener('pageshow', (event) => {
          let isBackForward = event.persisted;
          if (!isBackForward && window.performance && typeof window.performance.getEntriesByType === 'function') {
            const navEntries = window.performance.getEntriesByType('navigation');
            if (navEntries.length > 0) {
              isBackForward = (navEntries[0] as any).type === 'back_forward';
            }
          }
          if (!isBackForward) {
            // If it's a normal page load (not back/forward), clear the state
            sessionStorage.removeItem('navigated-back');
          }
          updateButtons();
        });

        // Initial paint
        updateButtons();
      }
      
      setupThemeToggle();
      setupMobileMenu();
      setupHistoryNavigation();
      document.addEventListener('astro:page-load', () => {
        setupThemeToggle();
        setupMobileMenu();
        setupHistoryNavigation();
      });
    </script>
  </body>
</html>
